# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Local PostgreSQL for Docker-based development.
POSTGRES_DB="bts_erp_os"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bts_erp_os?schema=public"
API_PORT="4010"

# Generated quote/order/invoice PDF branding.
# Set these before sharing customer-facing PDFs in production.
BTS_PDF_LOGO_PATH=""
BTS_COMPANY_NAME="Brick Tile Shop"
BTS_COMPANY_TAGLINE="Premium clay bricks, cladding tiles and architectural surfaces"
BTS_COMPANY_EMAIL="sales@bricktileshop.co.za"
BTS_COMPANY_PHONE="+27 (0) 00 000 0000"
BTS_COMPANY_WEBSITE="www.bricktileshop.co.za"
BTS_COMPANY_ADDRESS="South Africa"
BTS_BANK_ACCOUNT_NAME="Brick Tile Shop"
BTS_BANK_NAME=""
BTS_BANK_ACCOUNT_NUMBER=""
BTS_BANK_BRANCH_CODE=""
BTS_BANK_ACCOUNT_TYPE="Business Account"
BTS_BANK_REFERENCE_NOTE="Use the quote or invoice number as payment reference."

# Optional external publishing bridge for Instagram, Facebook, TikTok, Email, WhatsApp, and Pinterest.
# When set, the marketing publishing refresh path will call:
#   POST {MARKETING_PLATFORM_BRIDGE_BASE_URL}/publish
#   POST {MARKETING_PLATFORM_BRIDGE_BASE_URL}/sync
# with channel, caption, media, and job metadata.
MARKETING_PLATFORM_BRIDGE_BASE_URL=""
MARKETING_PLATFORM_BRIDGE_API_KEY=""

# Optional direct LinkedIn organization posting and metric sync.
# Uses LinkedIn Posts API, Images API, and Social Actions API when configured.
LINKEDIN_ACCESS_TOKEN=""
LINKEDIN_ORGANIZATION_URN="urn:li:organization:123456"
LINKEDIN_API_VERSION="202506"
