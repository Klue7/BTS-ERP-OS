model Product {
  id                      String                    @id @default(uuid())
  referenceId             String                    @unique
  publicSku               String                    @unique
  name                    String
  category                ProductCategory
  productType             ProductType
  finish                  ProductFinish?
  collectionName          String?
  presentationTags        String[]
  lifecycleStatus         ProductLifecycleStatus    @default(DRAFT)
  publishStatus           ProductPublishStatus      @default(NOT_READY)
  inventoryMode           InventoryMode             @default(DROPSHIP)
  availabilityStatus      ProductAvailabilityStatus @default(MISSING_SUPPLIER)
  pricingUnit             PricingUnit               @default(M2)
  sellPriceZar            Decimal?                  @db.Decimal(10, 2)
  primaryImageUrl         String?
  galleryImageUrl         String?
  faceImageUrl            String?
  heroImageUrl            String?
  latestTestReportUrl     String?
  latestTestReportName    String?
  latestTestLaboratoryName String?
  latestTestMethodStandard String?
  latestTestReportReference String?
  latestTestedAt          DateTime?
  latestTestIssuedAt      DateTime?
  description             String
  marketingCopy           String?
  technicalSpecifications Json
  lengthMm                Int?
  widthMm                 Int?
  heightMm                Int?
  coverageOrientation     CoverageOrientation?
  faceAreaM2              Decimal?                  @db.Decimal(10, 4)
  unitsPerM2              Decimal?                  @db.Decimal(10, 4)
  weightKg                Decimal?                  @db.Decimal(10, 3)
  piecesPerPallet         Int                       @default(1)
  boxesPerPallet          Int?
  palletsPerTruck         Int                       @default(24)
  reorderPoint            Int                       @default(0)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  productSuppliers        ProductSupplier[]
  stockMovements          StockMovement[]
  purchaseOrderLines      PurchaseOrderLine[]
  assets                  ProductAsset[]
  historyEvents           ProductHistoryEvent[]
  importRows              PriceListImportRow[]
  logisticsQuotes         LogisticsQuoteSnapshot[]
  assetLinks              AssetLink[]
  marketingCampaignLinks  MarketingCampaignProduct[]
  creativeDocuments       CreativeDocument[]
  creativeDocumentLinks   CreativeDocumentLink[]
  distributionPublications ProductDistributionPublication[]
  testResults             ProductTestResult[]
  businessDocuments       BusinessDocument[]
  domainEvents            DomainEventOutbox[]

  @@index([category])
  @@index([productType])
  @@index([lifecycleStatus])
  @@index([availabilityStatus])
}

model CustomerProfile {
  id                      String                   @id @default(uuid())
  customerKey             String                   @unique
  name                    String
  customerType            String?
  stage                   String?
  email                   String?
  phone                   String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  documents               BusinessDocument[]
  commsExternalIdentities CommsExternalIdentity[]
  commsConversations      CommsConversation[]
  customerPortalInvites   CustomerPortalInvite[]

  @@index([name])
  @@index([email])
  @@index([phone])
}

model CommsChannelConnection {
  id                String                  @id @default(uuid())
  connectionKey     String                  @unique
  provider          CommsProvider
  label             String
  status            CommsConnectionStatus   @default(SIMULATED)
  externalAccountId String?
  lastSyncedAt      DateTime?
  syncError         String?
  metadata          Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  conversations     CommsConversation[]

  @@index([provider, status])
}

model CommsExternalIdentity {
  id               String              @id @default(uuid())
  provider         CommsProvider
  externalUserId   String
  displayName      String?
  handle           String?
  email            String?
  phone            String?
  confidenceScore  Int                 @default(0)
  isVerified       Boolean             @default(false)
  rawProfile       Json?
  customerId       String?
  firstSeenAt      DateTime            @default(now())
  lastSeenAt       DateTime            @default(now())
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  customer         CustomerProfile?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  conversations    CommsConversation[]

  @@unique([provider, externalUserId])
  @@index([customerId])
  @@index([email])
  @@index([phone])
}

model CommsConversation {
  id                 String                      @id @default(uuid())
  conversationKey    String                      @unique
  provider           CommsProvider
  externalThreadId   String?
  channelConnectionId String?
  externalIdentityId String?
  customerId         String?
  customerName       String
  subject            String?
  status             CommsConversationStatus     @default(OPEN)
  category           CommsConversationCategory   @default(GENERAL)
  priority           CommsConversationPriority   @default(NORMAL)
  assignedTo         String?
  sourceUrl          String?
  lastMessage        String?
  lastMessageAt      DateTime                    @default(now())
  unreadCount        Int                         @default(0)
  metadata           Json?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  channelConnection  CommsChannelConnection?     @relation(fields: [channelConnectionId], references: [id], onDelete: SetNull)
  externalIdentity   CommsExternalIdentity?      @relation(fields: [externalIdentityId], references: [id], onDelete: SetNull)
  customer           CustomerProfile?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages           CommsMessage[]
  actions            CommsAction[]
  portalInvites      CustomerPortalInvite[]

  @@unique([provider, externalThreadId])
  @@index([status, lastMessageAt])
  @@index([provider, status])
  @@index([customerId])
  @@index([externalIdentityId])
}

model CommsMessage {
  id                String                  @id @default(uuid())
  messageKey        String                  @unique
  conversationId    String
  direction         CommsMessageDirection
  status            CommsMessageStatus      @default(RECEIVED)
  senderRole        String
  senderName        String
  body              String
  externalMessageId String?
  attachments       Json?
  metadata          Json?
  occurredAt        DateTime                @default(now())
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  conversation      CommsConversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, occurredAt])
  @@index([direction, status])
}

model CommsAction {
  id             String              @id @default(uuid())
  actionKey      String              @unique
  conversationId String
  actionType     CommsActionType
  status         CommsActionStatus   @default(OPEN)
  label          String
  actorLabel     String?
  payload        Json?
  occurredAt     DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  conversation   CommsConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, occurredAt])
  @@index([actionType, status])
}

model CustomerPortalInvite {
  id                   String                     @id @default(uuid())
  inviteKey            String                     @unique
  customerId           String
  sourceConversationId String?
  status               CustomerPortalInviteStatus @default(PROVISIONAL)
  portalPath           String                     @default("/portal")
  email                String?
  phone                String?
  lastSentAt           DateTime?
  metadata             Json?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  customer             CustomerProfile            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sourceConversation   CommsConversation?         @relation(fields: [sourceConversationId], references: [id], onDelete: SetNull)

  @@index([customerId, status])
  @@index([sourceConversationId])
}

model ProductTestResult {
  id          String                @id @default(uuid())
  productId   String
  resultType  ProductTestResultType
  resultValue Decimal               @db.Decimal(12, 4)
  resultUnit  String
  notes       String?
  sortOrder   Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, resultType])
  @@index([productId, sortOrder])
}

model ProductDistributionPublication {
  id                String                        @id @default(uuid())
  productId         String
  channel           ProductDistributionChannel
  channelType       DistributionChannelType
  connectionStatus  DistributionConnectionStatus @default(NOT_CONNECTED)
  publicationStatus DistributionPublicationStatus @default(NOT_POSTED)
  syncMode          DistributionSyncMode         @default(MANUAL)
  externalCatalogId String?
  externalListingId String?
  externalUrl       String?
  lastSyncedAt      DateTime?
  lastSyncError     String?
  publishedAt       DateTime?
  unpublishedAt     DateTime?
  metadata          Json?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  product           Product                      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, channel])
  @@index([channel])
  @@index([publicationStatus])
}

model Supplier {
  id                 String                   @id @default(uuid())
  supplierKey        String                   @unique
  name               String
  registeredName     String?
  tradingName        String?
  logoUrl            String?
  status             SupplierStatus           @default(ACTIVE)
  supplierType       SupplierType
  vendorRoles        SupplierVendorRole[]     @default([PRODUCT_SUPPLIER])
  capabilities       String[]
  regionLabel        String
  leadTimeDays       Int?
  leadTimeLabel      String?
  rating             Decimal?                 @db.Decimal(3, 2)
  blocker            String?
  defaultCurrency    String                   @default("ZAR")
  vatRegistered      Boolean                  @default(false)
  vatNumber          String?
  providesProducts   Boolean                  @default(true)
  providesTransport  Boolean                  @default(false)
  notes              String?
  contacts           Json?
  terms              Json?
  performance        Json?
  workflowMilestones Json?
  orderSummary       Json?
  historySummary     Json?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  locations          FulfillmentLocation[]
  productSuppliers   ProductSupplier[]
  purchaseOrders     PurchaseOrder[]
  businessDocuments  BusinessDocument[]
  rateCards          LogisticsRateCard[]
  logisticsQuotes    LogisticsQuoteSnapshot[]
  vendorContacts     VendorContact[]
  documents          VendorDocument[]
  commercialAccount  VendorCommercialAccount?
  vendorUsers        VendorUser[]
  workflowEvents     VendorWorkflowEvent[]
  domainEvents       DomainEventOutbox[]

  @@index([status])
}

model FulfillmentLocation {
  id               String                   @id @default(uuid())
  locationKey      String                   @unique
  supplierId       String?
  type             LocationType
  label            String
  streetAddress    String?
  postalCode       String?
  country          String
  region           String
  city             String
  latitude         Float?
  longitude        Float?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  supplier         Supplier?                @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  originRateCards  LogisticsRateCard[]
  productSuppliers ProductSupplier[]
  logisticsQuotes  LogisticsQuoteSnapshot[]
  purchaseOrders   PurchaseOrder[]

  @@unique([supplierId, label])
  @@index([type])
}

model VendorContact {
  id               String                  @id @default(uuid())
  supplierId       String
  department       String
  roleTitle        String?
  name             String
  email            String
  phone            String?
  preferredChannel PreferredContactChannel @default(EMAIL)
  notes            String?
  isPrimary        Boolean                 @default(false)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  supplier         Supplier                @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, department])
}

model VendorDocument {
  id               String             @id @default(uuid())
  supplierId       String
  documentKey      String             @unique
  name             String
  documentType     VendorDocumentType
  storagePath      String
  storedFileName   String
  mimeType         String?
  uploadedBy       String?
  fileSizeBytes    Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  supplier         Supplier           @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, documentType])
}

model VendorCommercialAccount {
  id                     String    @id @default(uuid())
  supplierId             String    @unique
  paymentTerms           String?
  deliveryTerms          String?
  minimumOrderValueZar   Decimal?  @db.Decimal(12, 2)
  standardDiscountPct    Decimal?  @db.Decimal(5, 2)
  moq                    String?
  currency               String    @default("ZAR")
  incoterms              String?
  creditLimitZar         Decimal?  @db.Decimal(12, 2)
  currentCreditBalanceZar Decimal  @default(0) @db.Decimal(12, 2)
  vatRegistered          Boolean   @default(false)
  vatNumber              String?
  standardVatRatePct     Decimal   @default(15) @db.Decimal(5, 2)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  supplier               Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model VendorUser {
  id           String          @id @default(uuid())
  supplierId   String
  email        String          @unique
  passwordHash String
  fullName     String
  roleLabel    String
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lastLoginAt  DateTime?
  supplier     Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  sessions     VendorSession[]
}

model VendorSession {
  id               String     @id @default(uuid())
  userId           String
  sessionTokenHash String     @unique
  expiresAt        DateTime
  createdAt        DateTime   @default(now())
  lastSeenAt       DateTime   @default(now())
  user             VendorUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model VendorWorkflowEvent {
  id             String                  @id @default(uuid())
  eventKey       String                  @unique
  supplierId     String?
  eventType      VendorWorkflowEventType
  actorLabel     String?
  payload        Json?
  occurredAt     DateTime
  createdAt      DateTime                @default(now())
  supplier       Supplier?               @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, occurredAt])
  @@index([eventType, occurredAt])
}

model DomainEventOutbox {
  id              String             @id @default(uuid())
  eventKey        String             @unique
  eventType       DomainEventType
  aggregateType   DomainAggregateType
  aggregateId     String
  supplierId      String?
  productId       String?
  payload         Json?
  status          DomainEventStatus  @default(PENDING)
  publishAttempts Int                @default(0)
  occurredAt      DateTime
  publishedAt     DateTime?
  lastError       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  supplier        Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  product         Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([status, occurredAt])
  @@index([aggregateType, aggregateId, occurredAt])
  @@index([supplierId, occurredAt])
  @@index([productId, occurredAt])
}

model ProductSupplier {
  id                   String              @id @default(uuid())
  productId            String
  supplierId           String
  originLocationId     String
  isDefault            Boolean             @default(false)
  unitCostZar          Decimal             @db.Decimal(10, 2)
  leadTimeDays         Int?
  minimumOrderQuantity Int?
  paymentTerms         String?
  incoterms            String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  product              Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
