  supplierId       String?
  productId        String?
  purchaseOrderId  String?
  goodsReceiptId   String?
  parentDocumentId String?
  issuedAt         DateTime
  dueAt            DateTime?
  totalAmount      Decimal                @db.Decimal(12, 2)
  balanceAmount    Decimal?               @db.Decimal(12, 2)
  currency         String                 @default("ZAR")
  snapshot         Json
